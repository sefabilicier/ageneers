# ─────────────────────────────────────────────
#  AI Dev Agent — Environment Variables
#  Copy this file to .env and fill in values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# --- FastAPI ---
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Logging ---
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console         # json | console

# --- Report persistence (survives server restart) ---
REPORTS_DIR=./reports

GROQ_API_KEY=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
GITHUB_TOKEN=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

# Comma-separated GitHub owners to always block (checked before allowlist)
# Example: "malicious-org,untrusted-user"
REPO_ALLOWLIST=sefabilicier
REPO_DENYLIST=
# for now, it is only allowed for me 

# Github Webhook
GITHUB_WEBHOOK_SECRET=
AI_AGENT_LABEL=

# Working directory for cloned repositories (isolated workspaces)
WORKSPACE_BASE_DIR=./workspaces
æ
#docker sandbox
USE_DOCKER_SANDBOX=true
DOCKER_CMD=
DOCKER_SANDBOX_IMAGE=
DOCKER_SANDBOX_MEMORY=512m
DOCKER_SANDBOX_CPUS=1
DOCKER_SANDBOX_TIMEOUT=120
DOCKER_CMD=

SANDBOX_IMAGE=

# API key for endpoint protection (leave empty means disabled)
API_KEY=


# --- Rate limiting ---
# Max requests to POST /api/tasks per minute per IP
RATE_LIMIT_TASKS=20/minute
# Max concurrent pipeline runs
MAX_CONCURRENT_TASKS=5

# --- Workspace cleanup ---
# Delete workspaces older than this many hours
WORKSPACE_MAX_AGE_HOURS=24
# Run cleanup every N hours
WORKSPACE_CLEANUP_INTERVAL_HOURS=6

# --- Audit log ---
AUDIT_LOG_PATH=